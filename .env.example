DROPBOARD_TOKEN=replace-me
# DROPBOARD_DATA_DIR=/custom/path/data/items
DROPBOARD_PIN=000000
DROPBOARD_SESSION_SECRET=replace-me

# ui language: en (default) | ko
NEXT_PUBLIC_DROPBOARD_LOCALE=en
# days before trashed items are purged by scripts/cleanup.mjs
DROPBOARD_TRASH_TTL_DAYS=30
# base URL used to build public share links (see "Sharing an item" in README).
# Without this, share links use whatever host/port the request came in on (e.g. localhost),
# which is useless to anyone but you. Set it to an address others can actually reach:
# your LAN IP for same-network sharing, or your tunnel/reverse-proxy domain for internet sharing.
# DROPBOARD_PUBLIC_URL=http://192.168.1.20:3000
