{
  "name": "dropboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "npm audit --omit=dev --audit-level=high",
    "cleanup": "node scripts/cleanup.mjs"
  },
  "dependencies": {
    "marked": "^18.0.7",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^7"
  },
  "description": "Self-hosted review board for AI-generated deliverables",
  "keywords": [
    "ai-agents",
    "self-hosted",
    "review",
    "artifacts"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lunemis/dropboard.git"
  },
  "homepage": "https://github.com/lunemis/dropboard#readme",
  "bugs": {
    "url": "https://github.com/lunemis/dropboard/issues"
  },
  "bin": {
    "dropboard": "bin/dropboard.mjs"
  }
}
